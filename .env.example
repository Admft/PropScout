# Copy to .env and fill in. Compose passes this file to the API container.

# --- Data providers ---
RENTCAST_API_KEY=            # required — property facts, AVM, comps (rentcast.io)
CENSUS_API_KEY=              # optional — raises rate limits (api.census.gov)
FRED_API_KEY=                # optional — live 30yr mortgage rate (fred.stlouisfed.org)

# --- LLM (set at least one; auto-detected) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LLM_PROVIDER=anthropic     # force a provider if both keys are set
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-4o

# --- Infra (defaults match docker-compose; override for local bare-metal dev) ---
# REDIS_URL=redis://localhost:6379/0
# DATABASE_URL=postgresql://housefax:housefax@localhost:5432/housefax

# --- Auth (NextAuth + Google) — frontend ---
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=generate-a-long-random-string
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_AUTH=1   # set to 1 when Google OAuth is ready

# --- Billing (Stripe) — frontend API routes ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_SINGLE=
# STRIPE_PRICE_PACK5=
# STRIPE_PRICE_PRO=
# STRIPE_DEMO_CUSTOMER_ID=    # for /settings/billing portal in early testing
