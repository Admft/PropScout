# Copy to .env and fill in. Compose passes this file to the API container.

# --- Data providers ---
RENTCAST_API_KEY=            # required — property facts, AVM, comps (rentcast.io)
CENSUS_API_KEY=              # optional — raises rate limits (api.census.gov)
FRED_API_KEY=                # optional — live 30yr mortgage rate (fred.stlouisfed.org)

# --- LLM (set at least one; auto-detected) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LLM_PROVIDER=anthropic     # force a provider if both keys are set
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-4o

# --- Infra (defaults match docker-compose; override for local bare-metal dev) ---
# REDIS_URL=redis://localhost:6379/0
# DATABASE_URL=postgresql://housefax:housefax@localhost:5432/housefax
