# Postgres 16 with both PostGIS (geospatial) and pgvector (RAG index).
# No stock image ships both, so we add pgvector to the PostGIS image via PGDG.
FROM postgis/postgis:16-3.4

RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-16-pgvector \
    && rm -rf /var/lib/apt/lists/*
